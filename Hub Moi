Players.LocalPlayer.Idled:Connect(function()
    VirtualUser:CaptureController()
    VirtualUser:ClickButton2(Vector2.new(0, 0))
end)

task.spawn(function()
    while task.wait(600) do
        pcall(function()
            local character = Players.LocalPlayer.Character
            if character then
                local humanoid = character:FindFirstChildOfClass("Humanoid")
                if humanoid and humanoid.Health > 0 then
                    humanoid.Jump = true
                end
            end
        end)
    end
end)

local function checkAndCollectSpecialSeed(object)
    if not object:IsA("BasePart") then return end
    local name = string.lower(object.Name)
    local shouldCollect = false
    if getgenv().VxezeKaitun.CollectGoldSeed and string.find(name, "gold") and string.find(name, "seed") then
        shouldCollect = true
    elseif getgenv().VxezeKaitun.CollectRainbowSeed and string.find(name, "rainbow") and string.find(name, "seed") then
        shouldCollect = true
    end
    if shouldCollect then
        pcall(function()
            local character = Players.LocalPlayer.Character
            local rootPart = character and character:FindFirstChild("HumanoidRootPart")
            if rootPart then
                local oldCFrame = rootPart.CFrame
                rootPart.CFrame = object.CFrame
                task.wait(0.1)
                rootPart.CFrame = oldCFrame
            end
        end)
    end
end

for _, v in ipairs(Workspace:GetDescendants()) do
    checkAndCollectSpecialSeed(v)
end

Workspace.DescendantAdded:Connect(function(newItem)
    task.spawn(function()
        checkAndCollectSpecialSeed(newItem)
    end)
end)

if getgenv().VxezeKaitun.FpsBoost then
    Lighting.GlobalShadows = false
    Lighting.FogEnd = 900000
    settings().Rendering.QualityLevel = Enum.QualityLevel.Level01

    local function applyPerformanceMode(object)
        if object:IsA("MeshPart") or object:IsA("Part") or object:IsA("CornerWedgePart") or object:IsA("TrussPart") then
            object.Material = Enum.Material.SmoothPlastic
            object.CastShadow = false
            local objName = string.lower(object.Name)
            local pName = object.Parent and string.lower(object.Parent.Name) or ""
            if string.find(objName, "tree") or string.find(objName, "leaf") or string.find(pName, "garden") or string.find(objName, "plant") then
                object.Transparency = 1
            end
        elseif object:IsA("Decal") or object:IsA("Texture") then
            object:Destroy()
        elseif object:IsA("ParticleEmitter") or object:IsA("Trail") then
            object.Enabled = false
        end
    end

    for _, item in ipairs(Workspace:GetDescendants()) do
        applyPerformanceMode(item)
    end

    Workspace.DescendantAdded:Connect(function(newItem)
        task.spawn(function()
            applyPerformanceMode(newItem)
        end)
    end)
end

